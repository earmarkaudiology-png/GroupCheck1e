            rollText = rolls.join(' + ');

            detail = ''
                + 'Ability: <b>' + h(abilityLabels[ability] || ability) + '</b>'
                + ' | Score: <b>' + score + '</b>'
                + ' | Roll: <b>' + rollText + ' = ' + total + '</b>'
                + ' | Need ≤ <b>' + score + '</b>'
                + ' — <b>' + (success ? 'SUCCESS' : 'FAILURE') + '</b>';

