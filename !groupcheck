            case 4: return { label: 'Half-Elf', chance: 10 };
            case 5: return { label: 'Halfling', chance: 15 };
            case 6: return { label: 'Half-Orc', chance: 15 };
            case 7: return { label: 'Human', chance: 10 };
            default: return { label: 'Human', chance: 10 };
