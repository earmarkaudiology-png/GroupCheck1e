    function detectInvisibleChance(hd, intBand) {
        var row = intVal(hd, 0);
        var band = intBandLabel(intBand);

        if (row < 7) return 0;
        if (row > 15) row = 15;

        var table = {
            7:  { '0-1':0,  '2-4':0,  '5-7':0,  '8-10':0,  '11-12':0,  '13-14':0,  '15-16':0,  '17+':5  },
            8:  { '0-1':0,  '2-4':0,  '5-7':0,  '8-10':0,  '11-12':0,  '13-14':0,  '15-16':5,  '17+':10 },
