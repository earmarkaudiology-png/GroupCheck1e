    function diseaseConAdjust(con) {
        con = intVal(con, 0);
        if (con < 3) { return 2; }
        if (con <= 5) { return 1; }
        if (con >= 18) { return -4; }
        if (con >= 16) { return -3; }
        if (con >= 13) { return -2; }
        if (con >= 10) { return -1; }
        return 0;
    }

