    function setDiseaseMods(playerid, value) {
        state[SCRIPT].showDiseaseModsByPlayer = state[SCRIPT].showDiseaseModsByPlayer || {};
        state[SCRIPT].showDiseaseModsByPlayer[playerid] = !!value;
