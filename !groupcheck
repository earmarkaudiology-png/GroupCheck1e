            + '<div>Breakage roll: <b>' + br.roll + '</b> on 1d20 vs survival target <b>' + br.target + '</b>.</div>'
            + '<div>Result: <b>' + (br.breaks ? 'FLASK BREAKS' : 'FLASK DOES NOT BREAK') + '</b>.</div>'
